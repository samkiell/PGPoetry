# --- Database ---
# MongoDB connection string (Atlas or local).
MONGODB_URI="mongodb+srv://user:password@cluster.mongodb.net/pgpoetry?retryWrites=true&w=majority"

# --- Auth.js (NextAuth v5) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Optional — enables "Sign in with Google". Leave blank to disable.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# The email address that should be granted the admin role on sign-up.
ADMIN_EMAIL="you@example.com"

# --- Cloudinary (image uploads) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="PGpoetry"
